# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mali_musavir

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-key
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mali-musavir-docs
S3_REGION=tr-east-1

# Email (SMTP / SES)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=
SMTP_FROM=Mali Müşavir <noreply@example.com>

# App
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# Encryption (AES-256 for sensitive fields)
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-string-here

# WhatsApp — Meta Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api)
# 1) developers.facebook.com → App oluştur → WhatsApp ürünü ekle
# 2) Test numarası veya onaylı gerçek numaradan PHONE_NUMBER_ID al
# 3) System User access token oluştur (whatsapp_business_messaging + whatsapp_business_management scope)
# 4) Business Manager'da şablon (template) gönder ve onay bekle (~5-60 dk)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=evrak_hatirlatma    # Meta'da onaylı şablon adı (opsiyonel ama 24s dışı için şart)
WHATSAPP_TEMPLATE_LANG=tr                   # Şablon dil kodu (tr | en | vb.)
WHATSAPP_API_VERSION=v20.0                  # Graph API versiyonu
