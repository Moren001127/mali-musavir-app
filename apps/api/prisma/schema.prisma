generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// TENANT (Ofis / Multi-tenant izolasyon)
// ============================================================
model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  email       String?
  phone       String?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                 User[]
  taxpayers             Taxpayer[]
  integrationConnections IntegrationConnection[]
  consents              Consent[]
  dataRetentionPolicies DataRetentionPolicy[]
  notifications         Notification[]
  kdvSessions           KdvControlSession[]
  smsTemplate           SmsTemplate?

  @@map("tenants")
}

// ============================================================
// AUTH & RBAC
// ============================================================
model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  userRoles    UserRole[]
  auditLogs    AuditLog[]
  notifications Notification[]

  @@unique([tenantId, email])
  @@map("users")
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique // ADMIN, STAFF, READONLY
  description String?
  permissions Json       @default("{}")
  createdAt   DateTime   @default(now())

  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  assignedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  isRevoked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  @@index([userId])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, etc.
  resource   String   // taxpayer, invoice, document, etc.
  resourceId String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// ============================================================
// CRM - MÜKELLEFLEr
// ============================================================
model Taxpayer {
  id          String       @id @default(cuid())
  tenantId    String
  type        TaxpayerType // GERCEK_KISI | TUZEL_KISI
  firstName   String?
  lastName    String?
  companyName String?
  taxNumber   String       // VKN (10 hane) veya TCKN (11 hane) - şifreli
  taxOffice   String
  email       String?
  phone       String?
  phones      String[]     // 3 telefon numarası
  emails      String[]     // 3 e-posta adresi
  address     String?
  notes       String?
  startDate   DateTime?    // İşe başlama tarihi
  endDate     DateTime?    // İşi bırakma tarihi
  evrakTeslimGunu     Int?          // 1-30 arası, her ayın kaçında bekleniyor
  whatsappEvrakTalep  Boolean       @default(false)
  whatsappEvrakGeldi  Boolean       @default(false)
  lastReminderSentAt  DateTime?
  isActive    Boolean      @default(true)
  // === OTOMASYON AJANLARI ===
  lucaSlug           String?  // Luca ZIP dosyasindaki slug ornegi "edeler_yem"
  mihsapId           String?  // Mihsap URL'indeki mukellef ID (/documents/BILANCO/1/110564)
  mihsapDefterTuru   String?  // "BILANCO" | "DEFTER_BEYAN"
  hattatId           String?  // Hattat yazılımındaki iç mükellef kodu (ZIP import eşleştirme için)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  contacts            Contact[]
  communicationLogs   CommunicationLog[]
  tasksReminders      TaskReminder[]
  taxDeclarations     TaxDeclaration[]
  incomeExpenseRecords IncomeExpenseRecord[]
  invoices            Invoice[]
  employees           Employee[]
  documents           Document[]
  kdvControlSessions  KdvControlSession[]
  monthlyStatuses     TaxpayerMonthlyStatus[]
  vendorDecisions     VendorMemoryDecision[]
  beyanConfig         TaxpayerBeyanConfig?
  beyanDurumlari      BeyanDurumu[]
  beyanKayitlari      BeyanKaydi[]
  cariHizmetler       CariHizmet[]
  cariHareketler      CariHareket[]
  earsivFaturalar     EarsivFatura[]

  @@index([tenantId])
  @@index([taxNumber])
  @@map("taxpayers")
}

// ============================================================
// MÜKELLEF BEYANNAME KONFIGURASYONU (Hattat-stil toplu beyanname takip)
// Her mükellef için hangi beyannameleri verir, dönemi ne.
// Ayarlar > Mükellef Beyanname Takip sayfasından düzenlenir.
// ============================================================
model TaxpayerBeyanConfig {
  id              String    @id @default(cuid())
  taxpayerId      String    @unique

  // Gelir/Kurumlar vergisi mükellef tipi (yıllık beyan için)
  incomeTaxType   String?   // "KURUMLAR" | "GELIR" | "BASIT_USUL" | null

  // KDV1 (Katma Değer Vergisi, 1 No'lu)
  kdv1Period      String?   // "AYLIK" | "UCAYLIK" | null (KDV mükellefi değilse)

  // KDV2 (Tevkifat) — aylık zorunlu, enabled bayrağı yeterli
  kdv2Enabled     Boolean   @default(false)

  // Muhtasar (MUHSGK — birleşik)
  muhtasarPeriod  String?   // "AYLIK" | "UCAYLIK" | null

  // Damga Vergisi (sürekli damga vergisi mükellefi mi)
  damgaEnabled    Boolean   @default(false)

  // Poşet Beyannamesi (3 aylık — plastik poşet kullananlar için)
  posetEnabled    Boolean   @default(false)

  // SGK Aylık Prim ve Hizmet Belgesi (çalışanı olanlar)
  sgkBildirgeEnabled Boolean @default(false)

  // E-Defter (bilanço usulü mükellefler için)
  eDefterPeriod   String?   // "AYLIK" | "UCAYLIK" | null (e-defter mükellefi değilse)

  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  taxpayer        Taxpayer  @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

  @@map("taxpayer_beyan_configs")
}

// ============================================================
// DÖNEM BAZLI BEYAN DURUMU
// Her mükellef + dönem + beyan tipi için tek kayıt.
// Beyanname verildiğinde/onaylandığında güncellenir.
// Dashboard'daki Toplu Beyanname tablosu bu veriyi özetler.
// ============================================================
model BeyanDurumu {
  id              String    @id @default(cuid())
  tenantId        String
  taxpayerId      String
  beyanTipi       String    // "KURUMLAR" | "GELIR" | "KDV1" | "KDV2" | "DAMGA" | "MUHSGK" | "POSET" | "BILDIRGE" | "EDEFTER"
  donem           String    // "2026-03" format (yyyy-mm)
  durum           String    @default("beklemede")  // "beklemede" | "onaylandi" | "hatali" | "muaf"
  onayTarihi      DateTime?
  tahakkukTutari  Decimal?  @db.Decimal(14, 2)
  notlar          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  taxpayer        Taxpayer  @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, taxpayerId, beyanTipi, donem])
  @@index([tenantId, donem])
  @@index([tenantId, beyanTipi, donem])
  @@index([taxpayerId])
  @@map("beyan_durumlari")
}

// ============================================================
// BEYANNAME KAYITLARI (Hattat'tan import edilen geçmiş beyannameler)
// Her beyanname için tek kayıt: mükellef + tip + dönem + tutar + (ops.) PDF.
// Import kaynağı Hattat Excel export'u. Status alanı şimdilik yok —
// ileride durum takibi eklenecek (gönderildi/onaylandı vb.).
// ============================================================
model BeyanKaydi {
  id              String    @id @default(cuid())
  tenantId        String
  taxpayerId      String
  beyanTipi       String    // "KDV1" | "KDV2" | "MUHSGK" | "DAMGA" | "POSET" | "KURUMLAR" | "GELIR" | "BILDIRGE" | "EDEFTER" | "GECICI_VERGI" | "DIGER"
  donem           String    // "2026-03" format (yyyy-mm), yıllık beyanlar için "2025-YIL"
  beyanTarihi     DateTime? // Beyannamenin verildiği tarih
  tahakkukTutari  Decimal?  @db.Decimal(14, 2)
  odemeTutari     Decimal?  @db.Decimal(14, 2) // İleride ödeme takibi için
  onayNo          String?   // GİB onay numarası / tahakkuk no
  // Dosya referansları (opsiyonel)
  pdfUrl          String?   // Tahakkuk fişi PDF — storage key
  beyannameUrl    String?   // Beyanname aslı PDF — storage key
  xmlUrl          String?   // e-Beyanname XML — storage key
  // İçe aktarım izleme
  kaynak          String    @default("manuel") // "hattat_excel" | "gib_agent" | "manuel"
  importBatchId   String?   // Aynı anda import edilen grubu tanımlar
  notlar          String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  taxpayer        Taxpayer  @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

  // Aynı mükellefin aynı dönem aynı tipinden 2 kayıt olmamalı
  @@unique([tenantId, taxpayerId, beyanTipi, donem])
  @@index([tenantId, donem])
  @@index([tenantId, beyanTipi])
  @@index([taxpayerId])
  @@index([importBatchId])
  @@map("beyan_kayitlari")
}

enum TaxpayerType {
  GERCEK_KISI
  TUZEL_KISI
}

model Contact {
  id         String   @id @default(cuid())
  taxpayerId String
  name       String
  title      String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  taxpayer   Taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model CommunicationLog {
  id         String   @id @default(cuid())
  taxpayerId String
  channel    String   // EMAIL, PHONE, MEETING, OTHER
  subject    String
  content    String?
  occurredAt DateTime
  createdAt  DateTime @default(now())

  taxpayer   Taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

  @@index([taxpayerId])
  @@map("communication_logs")
}

model TaskReminder {
  id          String    @id @default(cuid())
  taxpayerId  String
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  taxpayer    Taxpayer  @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

  @@index([taxpayerId, dueDate])
  @@map("tasks_reminders")
}

// ============================================================
// BEYANNAME & VERGİ TAKVİMİ
// ============================================================
model TaxCalendar {
  id              String              @id @default(cuid())
  declarationType String              // DeclarationType enum value
  periodMonth     Int?                // 1-12
  periodYear      Int
  periodQuarter   Int?                // 1-4
  dueDate         DateTime
  description     String?
  createdAt       DateTime            @default(now())

  declarations    TaxDeclaration[]

  @@index([dueDate])
  @@map("tax_calendar")
}

model TaxDeclaration {
  id              String            @id @default(cuid())
  taxpayerId      String
  taxCalendarId   String
  declarationType String
  periodLabel     String            // "2025/03" gibi
  status          DeclarationStatus @default(PENDING)
  assignedUserId  String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  taxpayer          Taxpayer           @relation(fields: [taxpayerId], references: [id])
  taxCalendar       TaxCalendar        @relation(fields: [taxCalendarId], references: [id])
  submissionStatuses SubmissionStatus[]

  @@index([taxpayerId, declarationType])
  @@map("tax_declarations")
}

enum DeclarationStatus {
  PENDING
  PREPARING
  READY
  SUBMITTED
  ACCEPTED
  REJECTED
}

model SubmissionStatus {
  id              String         @id @default(cuid())
  declarationId   String
  status          DeclarationStatus
  referenceNumber String?
  notes           String?
  changedAt       DateTime       @default(now())

  declaration     TaxDeclaration @relation(fields: [declarationId], references: [id], onDelete: Cascade)

  @@index([declarationId])
  @@map("submission_statuses")
}

// ============================================================
// FATURA / GELİR-GİDER / RAPORLAMA
// ============================================================
model Invoice {
  id           String        @id @default(cuid())
  taxpayerId   String
  invoiceNo    String
  status       InvoiceStatus @default(DRAFT)
  type         InvoiceType   // SATIS | ALIS | ARSIV
  issueDate    DateTime
  dueDate      DateTime?
  subtotal     Decimal       @db.Decimal(15, 2)
  vatAmount    Decimal       @db.Decimal(15, 2)
  totalAmount  Decimal       @db.Decimal(15, 2)
  currency     String        @default("TRY")
  notes        String?
  ublXml       String?       // UBL-TR XML içeriği (e-Fatura)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  taxpayer     Taxpayer      @relation(fields: [taxpayerId], references: [id])
  lines        InvoiceLine[]

  @@index([taxpayerId, status])
  @@map("invoices")
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  SENT
  ACCEPTED
  REJECTED
  ARCHIVED
}

enum InvoiceType {
  SATIS
  ALIS
  ARSIV
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(15, 4)
  unitPrice   Decimal  @db.Decimal(15, 4)
  vatRate     Decimal  @db.Decimal(5, 4) // 0.20, 0.10, 0.01, 0.00
  lineTotal   Decimal  @db.Decimal(15, 2)
  vatAmount   Decimal  @db.Decimal(15, 2)
  sortOrder   Int      @default(0)

  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_lines")
}

model IncomeExpenseRecord {
  id           String      @id @default(cuid())
  taxpayerId   String
  type         RecordType  // INCOME | EXPENSE
  category     String
  description  String?
  amount       Decimal     @db.Decimal(15, 2)
  vatAmount    Decimal     @db.Decimal(15, 2) @default(0)
  currency     String      @default("TRY")
  recordDate   DateTime
  invoiceId    String?
  createdAt    DateTime    @default(now())

  taxpayer     Taxpayer    @relation(fields: [taxpayerId], references: [id])

  @@index([taxpayerId, recordDate])
  @@map("income_expense_records")
}

enum RecordType {
  INCOME
  EXPENSE
}

model ReportSnapshot {
  id         String   @id @default(cuid())
  tenantId   String
  taxpayerId String?
  reportType String   // MONTHLY_INCOME, YEARLY_SUMMARY, etc.
  periodLabel String  // "2025/03"
  data       Json
  createdAt  DateTime @default(now())

  @@index([tenantId, reportType, periodLabel])
  @@map("report_snapshots")
}

// ============================================================
// BORDRO & SGK
// ============================================================
model Employee {
  id           String    @id @default(cuid())
  taxpayerId   String
  firstName    String
  lastName     String
  tcNo         String    // TCKN - şifreli
  startDate    DateTime
  endDate      DateTime?
  jobTitle     String?
  grossSalary  Decimal   @db.Decimal(15, 2)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  taxpayer     Taxpayer      @relation(fields: [taxpayerId], references: [id])
  payrollItems PayrollItem[]

  @@index([taxpayerId])
  @@map("employees")
}

model PayrollPeriod {
  id          String    @id @default(cuid())
  tenantId    String
  periodMonth Int       // 1-12
  periodYear  Int
  isClosed    Boolean   @default(false)
  closedAt    DateTime?
  createdAt   DateTime  @default(now())

  payrollItems    PayrollItem[]
  sgkDeclarations SgkDeclaration[]

  @@unique([tenantId, periodYear, periodMonth])
  @@map("payroll_periods")
}

model PayrollItem {
  id               String        @id @default(cuid())
  payrollPeriodId  String
  employeeId       String
  grossSalary      Decimal       @db.Decimal(15, 2)
  sgkWorkerShare   Decimal       @db.Decimal(15, 2)
  sgkEmployerShare Decimal       @db.Decimal(15, 2)
  unempWorkerShare Decimal       @db.Decimal(15, 2)
  incomeTax        Decimal       @db.Decimal(15, 2)
  stampTax         Decimal       @db.Decimal(15, 2)
  agi              Decimal       @db.Decimal(15, 2) @default(0)
  netSalary        Decimal       @db.Decimal(15, 2)
  calculationData  Json          // Hesaplama detayları
  createdAt        DateTime      @default(now())

  payrollPeriod    PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])
  employee         Employee      @relation(fields: [employeeId], references: [id])

  @@unique([payrollPeriodId, employeeId])
  @@map("payroll_items")
}

model SgkDeclaration {
  id              String        @id @default(cuid())
  payrollPeriodId String
  xmlContent      String?       // APHB XML
  status          String        @default("DRAFT") // DRAFT, READY, SUBMITTED
  submittedAt     DateTime?
  referenceNumber String?
  createdAt       DateTime      @default(now())

  payrollPeriod   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])

  @@map("sgk_declarations")
}

// ============================================================
// EVRAK YÖNETİMİ
// ============================================================
model Document {
  id           String           @id @default(cuid())
  taxpayerId   String
  title        String
  category     DocumentCategory @default(DIGER)
  mimeType     String
  sizeBytes    Int
  s3Key        String           // S3 object key
  currentVersionId String?
  isDeleted    Boolean          @default(false)
  // Geçerlilik / yenileme — vekaletname, imza sirküleri, ticaret sicil, vergi levhası gibi
  // belgelerin son kullanım tarihi. NULL = süresiz / takip edilmeyen.
  expiresAt    DateTime?
  // Bitime kaç gün kala dashboard'da uyar (default 30 gün)
  reminderDays Int              @default(30)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  taxpayer     Taxpayer         @relation(fields: [taxpayerId], references: [id])
  versions     DocumentVersion[]
  tags         DocumentTag[]

  @@index([taxpayerId, category])
  @@index([expiresAt])
  @@map("documents")
}

enum DocumentCategory {
  SOZLESME
  FATURA
  BEYANNAME
  EVRAK
  DIGER
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  versionNo  Int
  s3Key      String
  sizeBytes  Int
  uploadedBy String?
  notes      String?
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNo])
  @@map("document_versions")
}

model DocumentTag {
  id         String   @id @default(cuid())
  documentId String
  tag        String

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, tag])
  @@map("document_tags")
}

// ============================================================
// BİLDİRİMLER
// ============================================================
model Notification {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  title      String
  body       String
  type       String   // TAX_DEADLINE, TASK_DUE, SYSTEM, etc.
  isRead     Boolean  @default(false)
  readAt     DateTime?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, isRead])
  @@map("notifications")
}

// ============================================================
// ENTEGRASYON
// ============================================================
model IntegrationConnection {
  id          String   @id @default(cuid())
  tenantId    String
  provider    String   // GIB, EFATURA, SGK, LOGO, MIKRO, LUCA
  config      Json     // Şifreli kimlik bilgileri ve ayarlar
  isActive    Boolean  @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  jobs        IntegrationJob[]

  @@unique([tenantId, provider])
  @@map("integration_connections")
}

model IntegrationJob {
  id             String   @id @default(cuid())
  connectionId   String
  jobType        String   // DECLARATION_SUBMIT, INVOICE_SEND, SGK_SUBMIT, etc.
  status         String   @default("PENDING") // PENDING, RUNNING, SUCCESS, FAILED
  payload        Json?
  result         Json?
  errorMessage   String?
  attempts       Int      @default(0)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())

  connection     IntegrationConnection @relation(fields: [connectionId], references: [id])

  @@index([connectionId, status])
  @@map("integration_jobs")
}

// ============================================================
// KVKK
// ============================================================
model Consent {
  id          String   @id @default(cuid())
  tenantId    String
  subjectType String   // TAXPAYER, USER
  subjectId   String
  consentType String   // DATA_PROCESSING, MARKETING, etc.
  isGranted   Boolean
  grantedAt   DateTime?
  revokedAt   DateTime?
  ipAddress   String?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, subjectId])
  @@map("consents")
}

model DataRetentionPolicy {
  id              String   @id @default(cuid())
  tenantId        String
  resourceType    String   // taxpayer, invoice, payroll, document
  retentionMonths Int
  legalBasis      String?  // VUK 5 YIL, SGK 10 YIL, etc.
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, resourceType])
  @@map("data_retention_policies")
}

// ============================================================
// KDV KONTROL MODÜLü
// ============================================================

// Bir kontrol oturumu (191 veya 391 dönemi)
model KdvControlSession {
  id          String          @id @default(cuid())
  tenantId    String
  taxpayerId  String?
  type        KdvType         // ALIS (191) | SATIS (391)
  periodLabel String          // "2025/03" gibi
  status      SessionStatus   @default(DRAFT)
  notes       String?
  createdBy   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  taxpayer    Taxpayer?       @relation(fields: [taxpayerId], references: [id])
  kdvRecords  KdvRecord[]
  images      ReceiptImage[]
  results     ReconciliationResult[]

  @@index([tenantId, type, periodLabel])
  @@map("kdv_control_sessions")
}

enum KdvType {
  KDV_191         // 191 - İndirilecek KDV (alış)
  KDV_391         // 391 - Hesaplanan KDV (satış)
  ISLETME_GELIR   // İşletme defteri - Gelir sayfası
  ISLETME_GIDER   // İşletme defteri - Gider sayfası
}

enum SessionStatus {
  DRAFT       // Yeni oturum
  PROCESSING  // İşleniyor
  REVIEWING   // Kullanıcı inceliyor
  COMPLETED   // Tamamlandı
}

// Excel'den parse edilen her bir KDV satırı
model KdvRecord {
  id          String     @id @default(cuid())
  sessionId   String
  rowIndex    Int
  belgeNo     String?    // Belge/Fiş numarası
  belgeDate   DateTime?  // Belge tarihi
  karsiTaraf  String?    // Karşı taraf adı
  kdvMatrahi  Decimal?   @db.Decimal(15, 2)
  kdvTutari   Decimal    @db.Decimal(15, 2)
  kdvOrani    Decimal?   @db.Decimal(5, 2)
  aciklama    String?
  rawData     Json       // Ham Excel satır verisi
  createdAt   DateTime   @default(now())

  session     KdvControlSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Çok oranlı KDV: aynı Luca kaydı birden fazla eşleşme sonucuna sahip OLAMAZ,
  // ama ReconciliationResult tarafında imageId artık non-unique olduğu için
  // one-to-many ilişki (dizi) olarak tanımlanmalı. UI'da bir kaydın result'u
  // results[0] olarak alınır.
  results     ReconciliationResult[]

  @@index([sessionId])
  @@map("kdv_records")
}

// Yüklenen belge görselleri (JPEG/PNG)
model ReceiptImage {
  id           String    @id @default(cuid())
  sessionId    String
  s3Key        String
  originalName String
  mimeType     String
  sizeBytes    Int
  // OCR sonuçları
  ocrStatus    OcrStatus @default(PENDING)
  ocrBelgeNo   String?
  ocrDate      String?
  ocrKdvTutari String?            // NET KDV (tevkifatlıysa tam − tevkifat); reconciliation'da Luca ile karşılaştırılan değer
  ocrKdvTevkifat String?          // Tevkifat tutarı (varsa); null/0,00 = tevkifatsız fatura
  // OCR'dan gelen satıcı/tedarikçi unvanı — aynı belge no'lu farklı firmaları ayırmak için reconciliation'da kullanılır
  // @map: Railway DB'sinde kolon "ocrsatici" (lowercase) olarak yaratıldı (UI'dan elle eklendi).
  // Prisma client camelCase görür, DB'ye lowercase yazar/okur.
  ocrSatici    String?            @map("ocrsatici")
  ocrRawText   String?   // Ham OCR çıktısı
  ocrConfidence Float?   // 0-1 arası genel güven skoru
  // Alan-bazlı güven skorları (null = alan okunamadı)
  ocrBelgeNoConfidence Float?
  ocrDateConfidence    Float?
  ocrKdvConfidence     Float?
  ocrEngine    String?   // claude-haiku-4-5 | azure-vision | filename-only | ubl-xml-direct
  // Belge tipi (EFATURA / EARSIV / OKC_FIS / Z_RAPORU / MAKBUZ)
  ocrBelgeTipi String?
  // Çok oranlı KDV kırılımı (JSON) — [{oran, tutar, matrah}]
  // tutar = NET (tevkifat düşülmüş) tutar — kdvTutari toplamı = breakdown.tutar toplamı
  ocrKdvBreakdown Json?
  // OCR validation skoru — multi-pass doğrulama sonucu (0-1).
  // breakdown.tutar.sum === kdvTutari, matrah×rate consistency, geçerli oran kontrolü.
  // null = doğrulama yapılmadı (ör. UBL XML doğrudan parse).
  ocrValidationScore Float?
  // Kullanıcı düzeltmesi
  confirmedBelgeNo   String?
  confirmedDate      String?
  confirmedKdvTutari String?
  confirmedKdvTevkifat String?    // Kullanıcı düzeltmiş tevkifat tutarı
  // Kullanıcı onaylı KDV kırılımı (JSON)
  confirmedKdvBreakdown Json?
  isManuallyConfirmed Boolean @default(false)
  uploadedAt   DateTime  @default(now())

  session      KdvControlSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Çok oranlı fatura: bir image birden fazla Luca kaydıyla (ayrı orandaki
  // satırlarla) eşleşir → one-to-many.
  results      ReconciliationResult[]

  @@index([sessionId, ocrStatus])
  @@map("receipt_images")
}

enum OcrStatus {
  PENDING         // Henüz işlenmedi
  PROCESSING      // OCR çalışıyor
  SUCCESS         // Tüm alanlar yüksek güvenle okundu
  NEEDS_REVIEW    // Bir veya daha fazla alan eşik altında — kullanıcı teyidi bekler
  LOW_CONFIDENCE  // Hiçbir alan okunamadı
  FAILED          // OCR teknik olarak başarısız
}

// Eşleştirme sonuçları
model ReconciliationResult {
  id          String      @id @default(cuid())
  sessionId   String
  // @unique KALDIRILDI — çok oranlı Luca faturaları (aynı fatura için %20+%10
  // iki ayrı Luca satırı) tek fatura görselini paylaşır. Eski @unique constraint
  // bu durumu engelliyordu.
  kdvRecordId String?
  imageId     String?
  status      MatchStatus @default(UNMATCHED)
  matchScore  Float?      // 0-1 eşleşme skoru
  mismatchReasons String[] // Uyumsuzluk nedenleri
  resolvedBy  String?     // Kullanıcı ID
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime    @default(now())

  session     KdvControlSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  kdvRecord   KdvRecord?  @relation(fields: [kdvRecordId], references: [id])
  image       ReceiptImage? @relation(fields: [imageId], references: [id])

  @@index([sessionId, status])
  @@map("reconciliation_results")
}

enum MatchStatus {
  MATCHED         // Tam eşleşme
  PARTIAL_MATCH   // Kısmi eşleşme (1-2 alan uyuşmuyor)
  MISMATCH        // Uyumsuz
  UNMATCHED       // Eşleşme bulunamadı
  NEEDS_REVIEW    // Kullanıcı incelemesi gerekli
  CONFIRMED       // Kullanıcı tarafından teyit edildi
  REJECTED        // Kullanıcı tarafından reddedildi
}

// ============================================================
// MÜKELLEF AYLIK DURUM TAKİBİ
// ============================================================
model TaxpayerMonthlyStatus {
  id               String   @id @default(cuid())
  taxpayerId       String
  tenantId         String
  year             Int
  month            Int      // 1-12
  evraklarGeldi          Boolean  @default(false)
  evraklarIslendi        Boolean  @default(false)
  kontrolEdildi          Boolean  @default(false)
  beyannameVerildi       Boolean  @default(false)
  kdvKontrolEdildi       Boolean  @default(false)
  indirilecekKdvKontrol  Boolean  @default(false)
  hesaplananKdvKontrol   Boolean  @default(false)
  eArsivKontrol          Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt        DateTime @updatedAt

  taxpayer Taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

  @@unique([taxpayerId, year, month])
  @@index([tenantId, year, month])
  @@map("taxpayer_monthly_statuses")
}

// ============================================================
// OTOMASYON AJANLARI (Local script → Portal bridge)
// ============================================================
model AgentEvent {
  id         String   @id @default(cuid())
  tenantId   String
  agent      String   // "luca" | "mihsap" | "tebligat" ...
  action     String?  // "F2" | "F9" | "ZIP_MOVE" ...
  status     String   // "onaylandi" | "atlandi" | "hata" | "basarili" | "bilgi"
  message    String?
  mukellef   String?
  firma      String?
  fisNo      String?
  tutar      Decimal? @db.Decimal(14, 2)
  hesapKodu  String?
  kdv        String?
  meta       Json?
  ts         DateTime @default(now())

  @@index([tenantId, ts])
  @@index([tenantId, agent, ts])
  @@index([tenantId, mukellef])
  @@map("agent_events")
}

model AgentRule {
  id         String   @id @default(cuid())
  tenantId   String
  mukellef   String
  faaliyet   String?
  defterTuru String?
  profile    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, mukellef])
  @@index([tenantId])
  @@map("agent_rules")
}

model AgentStatus {
  id        String   @id @default(cuid())
  tenantId  String
  agent     String
  running   Boolean  @default(false)
  hedefAy   String?
  lastPing  DateTime @default(now())
  meta      Json?

  @@unique([tenantId, agent])
  @@map("agent_status")
}

// AI API kullanım takibi — tüm Claude çağrılarında bir kayıt
// source: "mihsap-fatura" | "fis-yazdirma" | diğer modüller
model AiUsageLog {
  id            String   @id @default(cuid())
  tenantId      String
  source        String   @default("mihsap-fatura") // hangi modül çağırdı
  mukellef      String?  // İşlem yapılan mükellef adı
  model         String   // "claude-haiku-4-5-20251001"
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  cacheReadTokens  Int   @default(0)
  cacheWriteTokens Int   @default(0)
  costUsd       Float    @default(0) // Hesaplanan USD maliyet
  karar         String?  // "onay" | "atla" | "emin_degil" | "ok" | "error"
  sebep         String?  @db.VarChar(200)
  belgeNo       String?
  durationMs    Int?     // API çağrı süresi
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, karar])
  @@index([tenantId, source, createdAt])
  @@index([tenantId, mukellef, createdAt])
  @@map("ai_usage_logs")
}

// Anthropic kontör (credit) yüklemeleri — kalan bakiye hesabı için
model AiCreditTopup {
  id         String   @id @default(cuid())
  tenantId   String
  amountUsd  Float    // Yüklenen tutar (USD)
  note       String?  // Kullanıcı notu (ör. "Nisan yüklemesi")
  addedAt    DateTime @default(now())
  addedBy    String?  // userId

  @@index([tenantId, addedAt])
  @@map("ai_credit_topups")
}

// ============================================================
// MIHSAP ENTEGRASYONU
// ============================================================

// MIHSAP oturum token'ı — eklenti tarafından otomatik senkronize edilir
model MihsapSession {
  id           String   @id @default(cuid())
  tenantId     String   @unique  // Her tenant için tek token
  token        String   @db.Text // JWT (şifreli saklanır — AES-GCM)
  email        String?  // Bilgi amaçlı (hangi hesap)
  updatedBy    String?  // userId / "extension"
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@map("mihsap_sessions")
}

// MIHSAP'tan çekilen faturalar — metadata + storage path
model MihsapInvoice {
  id                 String   @id @default(cuid())
  tenantId           String
  mukellefId         String   // Kendi sistemimizdeki mükellef ID
  mukellefMihsapId   String   // MIHSAP'taki userFirmaBilgisiId
  donem              String   // "2026-03" formatı (yıl-ay)
  faturaTuru         String   // "ALIS" | "SATIS" | "TEVKIFATLI_ALIS" vb.
  belgeTuru          String   // "E_FATURA" | "FIS" | "E_ARSIV" vb.
  faturaNo           String
  firmaKimlikNo      String?  // Karşı firma VKN/TCKN
  firmaUnvan         String?  // Karşı firma adı
  faturaTarihi       DateTime
  toplamTutar        Float
  onayDurumu         String?  // "ONAYLANMIS" vb.
  mihsapId           String   @unique  // MIHSAP'taki id (duplicate koruma)
  mihsapFileId       String?
  mihsapFaturaId     String?
  orjDosyaTuru       String?  // "XML" | "JPEG" vb.
  storageKey         String?  // Railway volume / S3 path: {tenant}/{mukellef}/{ay}/{belgeNo}.jpg
  storageUrl         String?  // Download URL (presigned veya internal)
  mihsapFileLink     String?  // Orijinal MIHSAP link (fallback)
  downloadedAt       DateTime?
  raw                Json?    // Orijinal MIHSAP payload
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId, mukellefId, donem])
  @@index([tenantId, donem, faturaTuru])
  @@index([tenantId, firmaKimlikNo])
  @@map("mihsap_invoices")
}

// Toplu çekme komutları — async çalıştırma + progress takibi
model MihsapFetchJob {
  id          String   @id @default(cuid())
  tenantId    String
  mukellefId  String
  donem       String   // "2026-03"
  faturaTuru  String?  // "ALIS" | "SATIS" | null (ikisi birden)
  status      String   @default("pending") // pending | running | done | failed
  totalCount  Int      @default(0)
  fetchedCount Int     @default(0)
  errorMsg    String?
  createdBy   String?
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("mihsap_fetch_jobs")
}

// ============================================================
// LUCA ENTEGRASYONU
// ============================================================

// Luca kullanıcı adı + şifresi — backend Playwright ile otomatik login olur.
// Şifre AES-256-GCM ile şifrelenmiş saklanır; ENCRYPTION_KEY env'den okunur.
model LucaCredential {
  id                String    @id @default(cuid())
  tenantId          String    @unique
  uyeNo             String    // Luca üye numarası (müşavir no)
  username          String    // Luca kullanıcı adı (mali müşavirin hesabı)
  encryptedPassword String    @db.Text  // AES-GCM şifrelenmiş
  // Cache edilmiş session cookies — her istek için yeniden login olmasın
  encryptedCookies  String?   @db.Text  // AES-GCM şifrelenmiş JSON
  cookiesExpiresAt  DateTime?
  lastLoginAt       DateTime?
  lastError         String?   // Son login denemesinde hata varsa
  isActive          Boolean   @default(true)
  updatedBy         String?
  updatedAt         DateTime  @updatedAt
  createdAt         DateTime  @default(now())

  @@map("luca_credentials")
}

// Luca oturum token/cookie'si — tarayıcı eklentisi tarafından senkronize edilir
// (Eski bookmarklet akışı için; credential tablosu varsa kullanılmaz)
model LucaSession {
  id          String   @id @default(cuid())
  tenantId    String   @unique   // Her tenant için tek oturum
  token       String   @db.Text  // JWT ya da cookie header değeri
  cookies     String?  @db.Text  // Luca için ek cookie header (PHPSESSID vs.)
  origin      String?            // "web.luca.com.tr" gibi
  email       String?            // Luca hesabı (bilgi amaçlı)
  updatedBy   String?            // userId / "extension"
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("luca_sessions")
}

// ============================================================
// MİZAN / GELİR TABLOSU / BİLANÇO
// ============================================================

// Luca'dan çekilen mizan snapshot'ı (tek dönem için tüm hesap kodları)
model Mizan {
  id          String        @id @default(cuid())
  tenantId    String
  taxpayerId  String
  donem       String        // "2026-03"
  donemTipi   String        @default("AYLIK") // AYLIK | GECICI_Q1 | GECICI_Q2 | GECICI_Q3 | GECICI_Q4 | YILLIK
  kaynak      String        @default("LUCA")  // LUCA | MANUEL | EXCEL
  status      String        @default("READY") // PENDING | READY | FAILED
  notes       String?
  rawExcelKey String?       // Mizan Excel orijinali (arşiv için)
  // Kesin Kayıt (lock) — kilitlendiğinde değişiklik/silme reddedilir
  locked      Boolean       @default(false)
  lockedAt    DateTime?
  lockedBy    String?
  lockNote    String?
  createdBy   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  hesaplar    MizanHesap[]
  gelirTablolari GelirTablosu[]
  bilancolar  Bilanco[]
  anomaliler  MizanAnomali[]

  @@index([tenantId, taxpayerId, donem])
  @@index([tenantId, createdAt])
  @@map("mizanlar")
}

// Mizan içindeki her hesap kodu satırı
model MizanHesap {
  id              String   @id @default(cuid())
  mizanId         String
  hesapKodu       String   // "600", "600.01", "120.01.001" gibi
  hesapAdi        String
  // Alt kırılım seviyesi (kaç nokta var): 0 = ana hesap, 1 = alt, 2 = detay
  seviye          Int      @default(0)
  borcToplami     Decimal  @default(0) @db.Decimal(18, 2)
  alacakToplami   Decimal  @default(0) @db.Decimal(18, 2)
  borcBakiye      Decimal  @default(0) @db.Decimal(18, 2)
  alacakBakiye    Decimal  @default(0) @db.Decimal(18, 2)
  rowIndex        Int      @default(0)

  mizan           Mizan    @relation(fields: [mizanId], references: [id], onDelete: Cascade)

  @@index([mizanId, hesapKodu])
  @@map("mizan_hesaplar")
}

// Mizan denetim sonucu — hesap kodu anomalileri
model MizanAnomali {
  id           String   @id @default(cuid())
  mizanId      String
  hesapKodu    String?
  tip          String   // "TDHP_DISI" | "ZIT_BAKIYE" | "EKSIK_HESAP" | "NET_OLMAYAN"
  seviye       String   @default("WARN") // INFO | WARN | ERROR
  mesaj        String
  detay        Json?

  mizan        Mizan    @relation(fields: [mizanId], references: [id], onDelete: Cascade)

  @@index([mizanId])
  @@map("mizan_anomaliler")
}

// Mizandan üretilen gelir tablosu snapshot'ı
model GelirTablosu {
  id           String   @id @default(cuid())
  tenantId     String
  taxpayerId   String
  mizanId      String?  // Hangi mizandan üretildi
  donem        String   // "2026-Q1" | "2026-03" | "2026-YILLIK"
  donemTipi    String   @default("GECICI_Q1")
  donemBaslangic DateTime?
  donemBitis   DateTime?

  // Standart gelir tablosu kalemleri (TDHP)
  brutSatislar       Decimal  @default(0) @db.Decimal(18, 2)
  satisIndirimleri   Decimal  @default(0) @db.Decimal(18, 2)
  netSatislar        Decimal  @default(0) @db.Decimal(18, 2)
  satisMaliyeti      Decimal  @default(0) @db.Decimal(18, 2)
  brutSatisKari      Decimal  @default(0) @db.Decimal(18, 2)
  faaliyetGiderleri  Decimal  @default(0) @db.Decimal(18, 2)
  faaliyetKari       Decimal  @default(0) @db.Decimal(18, 2)
  digerGelirler      Decimal  @default(0) @db.Decimal(18, 2)
  digerGiderler      Decimal  @default(0) @db.Decimal(18, 2)
  finansmanGiderleri Decimal  @default(0) @db.Decimal(18, 2)
  olaganKar          Decimal  @default(0) @db.Decimal(18, 2)
  olaganDisiGelir    Decimal  @default(0) @db.Decimal(18, 2)
  olaganDisiGider    Decimal  @default(0) @db.Decimal(18, 2)
  donemKari          Decimal  @default(0) @db.Decimal(18, 2)
  vergiKarsiligi     Decimal  @default(0) @db.Decimal(18, 2)
  donemNetKari       Decimal  @default(0) @db.Decimal(18, 2)

  // Detay: hangi hesap kodundan hangi tutar geldi (audit için)
  detay        Json?
  // Manuel düzeltmeler: kullanıcı 2. dönem için mizana kaydetmeden önce
  // maliyet/gider tahmini yapabilsin diye — her kalem için ek tutar
  duzeltmeler  Json?
  // Kesin Kayıt — kilitlendiğinde değişiklik/silme reddedilir
  locked       Boolean  @default(false)
  lockedAt     DateTime?
  lockedBy     String?
  lockNote     String?
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mizan        Mizan?   @relation(fields: [mizanId], references: [id], onDelete: SetNull)

  @@index([tenantId, taxpayerId, donem])
  @@index([tenantId, createdAt])
  @@map("gelir_tablolari")
}

// Mizandan üretilen bilanço snapshot'ı
model Bilanco {
  id           String   @id @default(cuid())
  tenantId     String
  taxpayerId   String
  mizanId      String?
  donem        String   // "2026-03"
  donemTipi    String   @default("AYLIK")
  tarih        DateTime?

  // Aktif toplamları (Dönen + Duran = Aktif Toplamı)
  donenVarliklar    Decimal @default(0) @db.Decimal(18, 2)
  duranVarliklar    Decimal @default(0) @db.Decimal(18, 2)
  aktifToplami      Decimal @default(0) @db.Decimal(18, 2)

  // Pasif toplamları (KVYK + UVYK + Özkaynak = Pasif Toplamı)
  kvYabanciKaynak   Decimal @default(0) @db.Decimal(18, 2)
  uvYabanciKaynak   Decimal @default(0) @db.Decimal(18, 2)
  ozkaynaklar       Decimal @default(0) @db.Decimal(18, 2)
  pasifToplami      Decimal @default(0) @db.Decimal(18, 2)

  // Detaylı kırılım (aktif + pasif tam hesap kodu bazlı)
  aktif        Json     // {"10": {...}, "12": {...}, ...}
  pasif        Json
  detay        Json?
  // Kesin Kayıt — kilitlendiğinde değişiklik/silme reddedilir
  locked       Boolean  @default(false)
  lockedAt     DateTime?
  lockedBy     String?
  lockNote     String?
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mizan        Mizan?   @relation(fields: [mizanId], references: [id], onDelete: SetNull)

  @@index([tenantId, taxpayerId, donem])
  @@index([tenantId, createdAt])
  @@map("bilancolar")
}

// KDV Kontrol çıktılarının arşivi — fiş yazdırmadaki gibi geriye dönük erişim
model KdvControlOutput {
  id            String   @id @default(cuid())
  tenantId      String
  sessionId     String?  // Hangi KDV kontrol oturumundan üretildi
  taxpayerId    String?
  mukellefName  String?  // Snapshot — görüntüleme için
  donem         String?  // "2026-02"
  tip           String?  // "KDV_191" | "KDV_391" | "ISLETME_GELIR" | "ISLETME_GIDER"
  matchedCount  Int      @default(0)
  partialCount  Int      @default(0)
  unmatchedCount Int     @default(0)
  totalRecords  Int      @default(0)
  totalImages   Int      @default(0)
  filename      String   // İndirme adı
  fileBytes     Bytes    // Excel dosyasının ikili içeriği
  fileSize      Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, taxpayerId, donem])
  @@index([sessionId])
  @@map("kdv_control_outputs")
}

// Luca'dan çekilen komutlar — hangi mükellef/dönem için ne tür muavin alındı
model LucaFetchJob {
  id            String    @id @default(cuid())
  tenantId      String
  sessionId     String?   // Bağlı KDV kontrol oturumu (varsa)
  mukellefId    String
  donem         String    // "2026-03"
  tip           String    // "KDV_191" | "KDV_391" | "ISLETME_GELIR" | "ISLETME_GIDER"
  status        String    @default("pending") // pending | running | done | failed
  recordCount   Int       @default(0)
  errorMsg      String?
  createdBy     String?
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([sessionId])
  @@map("luca_fetch_jobs")
}

// Fiş Yazdırma: oluşturulan Word çıktılarının arşivi
model FisYazdirmaOutput {
  id            String   @id @default(cuid())
  tenantId      String
  mukellefId    String?  // Seçili mükellef (varsa)
  mukellefName  String?  // Snapshot — görüntüleme için
  donem         String?  // "2026-02" (varsa)
  fileCount     Int      @default(0)
  pagesPerSheet Int?
  filename      String   // İndirme sırasında kullanılan orijinal ad
  fileBytes     Bytes    // Word belgesinin ikili içeriği
  fileSize      Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, mukellefId, donem])
  @@map("fis_yazdirma_outputs")
}

model AgentCommand {
  id         String   @id @default(cuid())
  tenantId   String
  agent      String   // "luca" | "mihsap" | ...
  action     String   // "basla" | "durdur" | "isle" | "ay_degistir"
  payload    Json     // {mukellefIds: [...], ay: "2026-03", ...}
  status     String   @default("pending") // pending | running | done | failed
  result     Json?    // Çalıştırma sonucu / hata
  createdAt  DateTime @default(now())
  startedAt  DateTime?
  finishedAt DateTime?
  createdBy  String?  // userId

  @@index([tenantId, status])
  @@index([tenantId, agent, createdAt])
  @@map("agent_commands")
}

// ============================================================
// SMS / WHATSAPP ŞABLONLARI
// ============================================================
model SmsTemplate {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  evrakTalepMesaji String   @default("Sayın {ad}, {dönem} dönemi evraklarınızı tarafımıza teslim etmenizi rica ederiz. Moren Mali Müşavirlik")
  evrakGeldiMesaji String   @default("Sayın {ad}, {dönem} dönemi evraklarınız tarafımıza ulaşmıştır. İşlemlerinize başlanmıştır. Moren Mali Müşavirlik")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("sms_templates")
}

// ============================================================
// MOREN AI — Mali Müşavir AI Asistanı
// ============================================================
// Her konuşma (thread), tenant başına izole.
model AiConversation {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?  // Konuşmayı başlatan kullanıcı
  title      String   @default("Yeni Konuşma")
  // Konuşmanın odaklandığı mükellef (varsa) — tool çağrıları bunu default alır
  taxpayerId String?
  // İstatistik — kümüle token/maliyet
  totalInputTokens     Int    @default(0)
  totalOutputTokens    Int    @default(0)
  totalCacheReadTokens Int    @default(0)
  totalCostUsd         Float  @default(0)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages   AiMessage[]

  @@index([tenantId, updatedAt])
  @@index([tenantId, taxpayerId])
  @@map("ai_conversations")
}

// Konuşma içindeki her mesaj — user/assistant/tool roller
model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // "user" | "assistant" | "tool"
  // Ham metin (markdown destekli). Sesli mesajlarda transcript burada.
  content        String   @db.Text
  // Tool-use mesajlarında: hangi tool, hangi input, hangi output (JSON)
  toolCalls      Json?    // [{ id, name, input }]
  toolResults    Json?    // [{ toolUseId, content }]
  // Sesli giriş/çıkış için
  audioKey       String?  // Storage key (opsiyonel, uzun saklama)
  // Token maliyeti (assistant mesajları için)
  inputTokens    Int?
  outputTokens  Int?
  cacheReadTokens  Int?
  cacheWriteTokens Int?
  costUsd       Float?
  model         String?  // "claude-sonnet-4-5"
  durationMs    Int?
  createdAt     DateTime @default(now())

  conversation  AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

// ============================================================
// FIRMA HAFIZASI (Vendor Memory) + ONAY KUYRUGU (Pending Decisions)
// ============================================================
// AI fatura kategorize ederken her firma (VKN/TCKN) icin gecmis onay
// sayaclarini kullanir. Sapma tespit edilirse (gecmisten farkli karar)
// islem otomatik gecmez, PendingDecision'a dusup insan onayi bekler.

// Her firma (VKN/TCKN) icin hafiza kaydi — toplam onay + son kullanim.
model VendorMemory {
  id            String   @id @default(cuid())
  tenantId      String
  firmaKimlikNo String   // VKN (10 hane) veya TCKN (11 hane)
  firmaUnvan    String?  // Son gorulen unvan (degisebilir)
  toplamOnay    Int      @default(0)
  sonKullanim   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  decisions     VendorMemoryDecision[]

  @@unique([tenantId, firmaKimlikNo])
  @@index([tenantId, sonKullanim])
  @@map("vendor_memory")
}

// Her firma icin kategori bazli karar sayaci.
// fatura: kararTipi='fatura', kategori=hesapKodu, altKategori=null
// isletme: kararTipi='isletme', kategori=kayitTuru, altKategori=altTuru
model VendorMemoryDecision {
  id              String   @id @default(cuid())
  vendorMemoryId  String
  taxpayerId      String?  // YENİ — hangi mükellef için öğrenildi (null = eski ortak kayıtlar)
  kararTipi       String   // "fatura" | "isletme"
  kategori        String   // fatura: hesapKodu; isletme: kayitTuru
  altKategori     String?  // sadece isletme: altTuru
  onayAdedi       Int      @default(0)
  sonKullanim     DateTime @default(now())
  createdAt       DateTime @default(now())

  vendorMemory    VendorMemory @relation(fields: [vendorMemoryId], references: [id], onDelete: Cascade)
  taxpayer        Taxpayer?    @relation(fields: [taxpayerId], references: [id], onDelete: SetNull)

  // Nullable taxpayerId ile standart @@unique çalışmadığı için SQL migration'da
  // COALESCE indexi oluşturuldu. Burada indeksleme yalnızca performans için:
  @@index([vendorMemoryId, onayAdedi])
  @@index([vendorMemoryId, taxpayerId])
  @@index([taxpayerId])
  @@map("vendor_memory_decisions")
}

// Onay Kuyrugu — AI sapma tespit ettiginde insan onayi bekler.
model PendingDecision {
  id              String   @id @default(cuid())
  tenantId        String
  taxpayerId      String?  // YENİ: Firma Hafızası mükellef-bazlı öğrenme için
  mukellef        String?
  firmaKimlikNo   String?
  firmaUnvan      String?
  belgeNo         String?
  belgeTuru       String?
  faturaTarihi    DateTime?
  tutar           Decimal? @db.Decimal(14, 2)
  kararTipi       String   // "fatura" | "isletme"
  aiKarari        Json     // AI'nin onerdigi karar (tam response)
  gecmisBeklenen  Json?    // VendorMemory'den top kategori + sayi
  sapmaSebep      String   @db.VarChar(500)
  imageBase64     String?  @db.Text  // Fatura gorseli (kucuk tutulur)
  durum           String   @default("bekliyor") // "bekliyor" | "onaylandi" | "reddedildi"
  sonucKarari     Json?    // Kullanici override ettiyse final karar
  onayAlan        String?  // userId
  onayTarihi      DateTime?
  notlar          String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, durum, createdAt])
  @@index([tenantId, createdAt])
  @@map("pending_decisions")
}

// ============================================================
// GALERİ — HGS İhlal Sorgulama Modülü
// Araç plakalarını kayıtlı tutar, KGM HGS İhlal takip sitesinden
// periyodik (ör. her Pazartesi) otomatik sorgu yapar ve sonuçları saklar.
// ============================================================
model Arac {
  id          String   @id @default(cuid())
  tenantId    String
  plaka       String   // "34 ABC 123" veya "34ABC123" — normalize edilir
  marka       String?  // Opsiyonel: araç markası
  model       String?  // Opsiyonel: araç modeli
  sahipAd     String?  // Opsiyonel: araç sahibi (galerici müşteri vb.)
  taxpayerId  String?  // Opsiyonel: portaldaki mükellefe bağlama
  aktif       Boolean  @default(true)
  notlar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hgsSonuclari HgsIhlalSorguSonucu[]

  @@unique([tenantId, plaka])
  @@index([tenantId])
  @@index([taxpayerId])
  @@map("araclar")
}

// Her sorgu bir kayıt — aynı plaka için dönem dönem birden fazla kayıt olur
model HgsIhlalSorguSonucu {
  id           String   @id @default(cuid())
  tenantId     String
  aracId       String
  sorguTarihi  DateTime @default(now())
  durum        String   @default("beklemede") // "beklemede" | "basarili" | "hatali"
  ihlalSayisi  Int      @default(0)
  toplamTutar  Decimal? @db.Decimal(14, 2)
  detaylar     Json?    // Ham ihlal detayları (tarih, tutar, ücret noktası vb. array)
  rawHtml      String?  @db.Text // Sorgu HTML snapshoti (debug için)
  hataMesaji   String?  // durum=hatali ise sebep
  kaynak       String   @default("manuel") // "manuel" | "cron_pazartesi" | "tek_sefer"

  arac         Arac     @relation(fields: [aracId], references: [id], onDelete: Cascade)

  @@index([tenantId, sorguTarihi])
  @@index([aracId, sorguTarihi])
  @@map("hgs_ihlal_sorgu_sonuclari")
}

// ============================================================
// CARİ KASA — Müşteri Hizmetleri ve Ödeme Takibi
// ============================================================

// Mükellefe tanımlanan tekrar eden hizmetler (muhasebe ücreti, bordro, SGK, vb.)
// Her ayın 1. günü cron otomatik tahakkuk kaydı oluşturur.
model CariHizmet {
  id            String    @id @default(cuid())
  tenantId      String
  taxpayerId    String
  hizmetAdi     String    // "Muhasebe Ücreti", "Bordro", "SGK", "Yıllık Kapanış", vb.
  tutar         Decimal   @db.Decimal(14, 2)
  periyot       String    // "AYLIK" | "UCAYLIK" | "ALTIAYLIK" | "YILLIK"
  baslangicAy   String    // "2026-01" formatı — bu aydan itibaren tahakkuk geçer
  bitisAy       String?   // opsiyonel, belirtilirse o aya kadar tahakkuk edilir
  aktif         Boolean   @default(true)
  sonTahakkukAy String?   // "2026-04" — duplicate önleme (cron kontrolü)
  notlar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  taxpayer      Taxpayer       @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
  hareketler    CariHareket[]

  @@index([tenantId, taxpayerId])
  @@index([tenantId, aktif])
  @@map("cari_hizmetler")
}

// Cari hareketler — tahakkuk (borç) ve tahsilat (alacak) kayıtları.
// Bakiye = SUM(TAHAKKUK) - SUM(TAHSILAT) olarak hesaplanır.
model CariHareket {
  id             String    @id @default(cuid())
  tenantId       String
  taxpayerId     String
  hizmetId       String?   // Tahakkuksa hizmete bağlı; manuel ödeme ise null
  tarih          DateTime
  tip            String    // "TAHAKKUK" | "TAHSILAT" | "IADE" | "DUZELTME"
  tutar          Decimal   @db.Decimal(14, 2)
  aciklama       String?
  odemeYontemi   String?   // "NAKIT" | "HAVALE" | "POS" | "CEK" | "SENET" | null
  belgeNo        String?   // Dekont/makbuz no
  donem          String?   // "2026-04" — tahakkuk hangi ayın, tahsilat hangi aya ait
  otoOlusturuldu Boolean   @default(false)
  createdAt      DateTime  @default(now())
  createdBy      String?

  taxpayer       Taxpayer     @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
  hizmet         CariHizmet?  @relation(fields: [hizmetId], references: [id], onDelete: SetNull)

  @@index([tenantId, taxpayerId, tarih])
  @@index([tenantId, tarih])
  @@index([tenantId, tip])
  @@map("cari_hareketler")
}

// === E-ARŞİV / E-FATURA ===
// Luca'dan toplu çekilen e-arşiv (SATIŞ) ve e-fatura (ALIŞ) faturaları.
// Orijinal UBL XML + PDF saklanır (denetim için), parse edilen alanlar ayrı kolonlarda.
model EarsivFatura {
  id             String     @id @default(cuid())
  tenantId       String
  taxpayerId     String
  tip            EarsivTip  // SATIS | ALIS
  donem          String     // "2026-03" YYYY-MM
  faturaNo       String
  faturaTarihi   DateTime
  ettn           String?    // E-fatura/e-arşiv UUID
  satici         String?
  saticiVergiNo  String?
  alici          String?
  aliciVergiNo   String?
  matrah         Decimal?   @db.Decimal(18, 2)
  kdvTutari      Decimal?   @db.Decimal(18, 2)
  kdvOrani       Decimal?   @db.Decimal(5, 2)
  toplamTutar    Decimal?   @db.Decimal(18, 2)
  paraBirimi     String?    @default("TL")
  aciklama       String?
  durum          String?    // KABUL | RED | IPTAL | BEKLEMEDE
  xmlContent     String?    @db.Text  // orijinal UBL XML
  pdfStorageKey  String?    // S3 key veya disk path; ham PDF
  zipSourceName  String?    // Hangi ZIP'ten geldi
  fetchJobId     String?    // Hangi LucaFetchJob ile çekildi
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  taxpayer       Taxpayer   @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, taxpayerId, tip, faturaNo])
  @@index([tenantId, taxpayerId, donem, tip])
  @@index([tenantId, faturaTarihi])
  @@index([fetchJobId])
  @@map("earsiv_faturalar")
}

enum EarsivTip {
  SATIS
  ALIS
}
